<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        CONSOLE appender
        Shows INFO and above — enough signal without flooding Railway's
        log pipeline (500 logs/sec rate limit)
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        FILE appender — INFO and above, rolling daily / 50 MB
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/app.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/app-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>


    <!--
         DEV PROFILE
         In dev we want to see SQL and DEBUG output locally.
    -->
    <springProfile name="dev">

        <!-- SQL queries visible in dev -->
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <!-- bind parameters only to file — console gets noisy enough already -->
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>

        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>

    </springProfile>


    <!--
         PROD PROFILE
         Console and file both at INFO. Hibernate SQL silenced.
         Spring framework noise reduced to WARN.
         App package at INFO — no DEBUG spam in production.
    -->
    <springProfile name="prod">

        <!-- SQL silenced in prod — too verbose, exposes query details -->
        <logger name="org.hibernate.SQL" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>

        <!-- bind params silenced in prod — could expose sensitive data -->
        <logger name="org.hibernate.orm.jdbc.bind" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>

        <!-- Spring itself is very chatty, tone it down -->
        <logger name="org.springframework" level="WARN" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <!-- Application package — INFO is sufficient in production -->
        <logger name="com.example.trekking_app" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>

    </springProfile>

</configuration>